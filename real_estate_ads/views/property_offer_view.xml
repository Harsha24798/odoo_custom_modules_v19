<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>

        <!-- List View -->
        <record id="view_property_offers_list" model="ir.ui.view">
            <field name="name">estate.property.offers.list</field>
            <field name="model">estate.property.offers</field>
            <field name="arch" type="xml">
                <list string="Property Offers">
                    <field name="price" widget="monetary"/>
                    <field name="status" widget="badge" decoration-warning="status == 'pending'" decoration-success="status == 'accepted'" decoration-danger="status == 'refused'"/>
                    <field name="partner_id"/>
                    <field name="property_id"/>
                    <field name="validity"/>
                    <field name="deadline"/>
                    <field name="creation_date" optional="hide"/>
                </list>
            </field>
        </record>

        <!-- Form View -->
        <record id="view_property_offers_form" model="ir.ui.view">
            <field name="name">estate.property.offers.form</field>
            <field name="model">estate.property.offers</field>
            <field name="arch" type="xml">
                <form string="Property Offers">
                    <sheet>
                        <group>
                            <group>
                                <field name="price" widget="monetary"/>
                                <field name="status" widget="badge" decoration-warning="status == 'pending'" decoration-success="status == 'accepted'" decoration-danger="status == 'refused'"/>
                                <field name="partner_id"/>
                                <field name="property_id"/>
                            </group>
                            <group>
                                <field name="validity"/>
                                <field name="deadline"/>
                                <field name="creation_date" optional="hide"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Action View -->
        <record id="action_property_offers" model="ir.actions.act_window">
            <field name="name">estate.property.offers</field>
            <field name="res_model">estate.property.offers</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create your first property Offer
                </p>
            </field>
        </record>

        <!-- Action Menu -->
        <!-- Settings only for sales and managers -->
        <menuitem id="menu_property_offer" name="Offers" parent="menu_settings" action="action_property_offers" groups="real_estate_ads.group_property_sales,real_estate_ads.group_property_manager"/>

    </data>
</odoo>