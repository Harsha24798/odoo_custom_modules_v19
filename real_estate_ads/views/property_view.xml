<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>

        <!-- Search View -->
        <record id="view_property_search" model="ir.ui.view">
            <field name="name">estate.property.search</field>
            <field name="model">estate.property</field>
            <field name="arch" type="xml">
                <search string="Search Property">
                    <!-- Search Fields -->
                    <field name="name"/>
                    <field name="postcode"/>
                    <field name="type_id"/>

                    <!-- State Filters -->
                    <filter name="new" string="New" domain="[('state', '=', 'new')]"/>
                    <filter name="offer_received" string="Offer Received" domain="[('state', '=', 'received')]"/>
                    <filter name="accepted" string="Offer Accepted" domain="[('state', '=', 'accepted')]"/>
                    <filter name="sold" string="Sold" domain="[('state', '=', 'sold')]"/>
                    <filter name="canceled" string="Canceled" domain="[('state', '=', 'cancel')]"/>
                    <separator/>

                    <!-- Price Range Filters -->
                    <filter name="price_0_250k" string="0-250k" domain="[('expected_price', '&gt;=', 0), ('expected_price', '&lt;=', 250000)]"/>
                    <filter name="price_250k_500k" string="250k-500k" domain="[('expected_price', '&gt;', 250000), ('expected_price', '&lt;=', 500000)]"/>
                    <filter name="price_500k_750k" string="500k-750k" domain="[('expected_price', '&gt;', 500000), ('expected_price', '&lt;=', 750000)]"/>
                    <filter name="price_750k_plus" string="750k+" domain="[('expected_price', '&gt;', 750000)]"/>

                    <!-- Group By Options (flat filters for search view) -->
                    <filter name="group_by_type" string="Property Type" context="{'group_by': 'type_id'}"/>
                    <filter name="group_by_state" string="State" context="{'group_by': 'state'}"/>
                </search>
            </field>
        </record>

        <!-- List View -->
        <record id="view_property_list" model="ir.ui.view">
            <field name="name">estate.property.list</field>
            <field name="model">estate.property</field>
            <field name="arch" type="xml">
                <list string="Property">
                    <field name="name"/>
                    <field name="offer_count"/>
                    <field name="postcode"/>
                    <field name="date_availability" optional="show"/>
                    <field name="description" optional="hide"/>
                    <field name="expected_price" widget="monetary"/>
                    <field name="selling_price" widget="monetary"/>
                    <field name="bedrooms" optional="show"/>
                    <field name="living_area" optional="show"/>
                    <field name="facades" optional="hide"/>
                    <field name="garage" optional="hide"/>
                    <field name="garden" optional="hide"/>
                    <field name="garden_area" optional="hide"/>
                    <field name="garden_orientation" optional="hide"/>
                    <field name="state" widget="label_selection" options="{'classes': {'new': 'info', 'received': 'warning', 'accepted': 'primary', 'sold': 'success', 'cancel': 'danger'}}"/>
                </list>
            </field>
        </record>

        <!-- Form View -->
        <record id="view_property_form" model="ir.ui.view">
            <field name="name">estate.property.form</field>
            <field name="model">estate.property</field>
            <field name="arch" type="xml">
                <form string="Property">
                    <header>
                        <!-- Mark as Sold / Cancel buttons: visible for Sales/Manager groups only -->
                        <button name="action_sold" string="Mark as Sold" type="object" class="btn-primary" groups="real_estate_ads.group_property_sales"/>
                        <button name="action_cancel" string="Cancel" type="object" class="btn-danger" groups="real_estate_ads.group_property_sales"/>
                        <field name="state" widget="statusbar"/>
                    </header>
                    <sheet>

                        <div class="oe_button_box" name="button_box">
                            <button name="action_property_view_offers" string="Offers" type="object" class="oe_stat_button" icon="fa-heart">
                                <field name="offer_count" widget="statinfo"/>
                            </button>
                        </div>

                        <!-- Main property information section -->
                        <group>
                            <!-- Property: read-only for users/sales, editable for manager -->
                            <field name="name" placeholder="Property Name" readonly="not is_manager"/>
                            <field name="type_id" invisible="not is_manager"/>
                            <field name="tag_ids" widget="many2many_tags" options="{'color_field': 'color'}" invisible="not is_manager"/>
                            <field name="is_manager" invisible="1"/>

                            <group>
                                <field name="postcode" readonly="not is_manager"/>
                                <field name="date_availability" readonly="not is_manager"/>
                            </group>


                            <group>
                                <!-- Price fields: always read-only (computed) -->
                                <field name="expected_price" widget="monetary" readonly="not is_manager"/>
                                <field name="best_offer" widget="monetary" readonly="1"/>
                                <field name="selling_price" widget="monetary" readonly="1"/>
                            </group>
                        </group>

                        <!-- Property Details Notebook -->
                        <notebook>
                            <page string="Description">
                                <group>
                                    <!-- Description: read-only for users, editable for sales/manager -->
                                    <field name="description" readonly="not is_manager"/>
                                    <field name="bedrooms" readonly="not is_manager"/>
                                    <field name="living_area" readonly="not is_manager"/>
                                    <field name="facades" readonly="not is_manager"/>
                                    <field name="garage" widget="boolean_toggle" readonly="not is_manager"/>
                                    <field name="garden" readonly="not is_manager"/>
                                    <field name="garden_area" invisible="not garden" readonly="not is_manager"/>
                                    <field name="garden_orientation" invisible="not garden" widget="selection_badge" readonly="not is_manager"/>
                                    <field name="total_area" readonly="1"/>
                                </group>
                            </page>

                            <!-- Offers Tab: accessible to all groups with full CRUD (via record rules) -->
                            <page string="Offers">
                                <field name="offer_ids">
                                    <list editable="bottom" decoration-success="status == 'accepted'" decoration-danger="status == 'refused'">
                                        <field name="price"/>
                                        <field name="partner_id"/>
                                        <field name="creation_date"/>
                                        <field name="validity"/>
                                        <field name="deadline" widget="remaining_days"/>
                                        <field name="status" nolabel="1" readonly="True"/>

                                        <!-- Accept Button: visible only for Sales/Manager groups -->
                                        <button name="action_accept_offer" string="Accept" type="object" class="btn-success" groups="real_estate_ads.group_property_sales"/>
                                        <button name="action_refuse_offer" string="Refuse" type="object" class="btn-danger" groups="real_estate_ads.group_property_sales"/>
                                    </list>
                                </field>
                            </page>

                            <!-- Other Information Tab -->
                            <page string="Other Info">
                                <group>
                                    <field name="sales_id" widget="many2one_avatar_user"/>
                                    <field name="buyer_id"/>
                                    <field name="phone" widget="phone" readonly="1"/>
                                </group>
                            </page>

                        </notebook>

                    </sheet>
<!--                    <div class="oe_chatter">-->
<!--                        <chatter groups="real_estate_ads.group_property_manager"/>-->
<!--                    </div>-->
                </form>
            </field>
        </record>

        <!-- Kanban View -->
        <record id="estate_property_kanban_view" model="ir.ui.view">
            <field name="name">estate.property.kanban</field>
            <field name="model">estate.property</field>
            <field name="arch" type="xml">
                <kanban class="o_kanban_mobile" sample="1" default_group_by="state">
                    <field name="name"/>
                    <field name="postcode"/>
                    <field name="expected_price"/>
                    <field name="state"/>
                    <field name="type_id"/>
                    <field name="bedrooms"/>
                    <field name="living_area"/>
                    <templates>
                        <t t-name="card">
                            <div class="d-flex align-items-baseline mb-2">
                                <strong class="fw-bolder fs-5 me-2"><field name="name"/></strong>
                                <span class="badge text-bg-info" t-if="record.type_id.raw_value">
                                    <field name="type_id"/>
                                </span>
                                <field name="state" widget="label_selection" class="ms-auto flex-shrink-0" options="{'classes': {'new': 'info', 'received': 'warning', 'accepted': 'primary', 'sold': 'success', 'cancel': 'danger'}}"/>
                            </div>
                            <footer class="align-items-end">
                                <div class="d-flex flex-wrap gap-2 text-muted text-nowrap">
                                    <span><i class="fa fa-map-marker" title="Location"/> <field name="postcode"/></span>
                                    <span><i class="fa fa-bed" title="Bedrooms"/> <field name="bedrooms"/> Beds</span>
                                    <span><i class="fa fa-ruler" title="Area"/> <field name="living_area"/> sqm</span>
                                </div>
                                <div class="fw-bolder ms-auto">
                                    <field name="expected_price" widget="monetary"/>
                                </div>
                            </footer>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <!-- Pivot View -->
        <record id="estate_property_pivot_view" model="ir.ui.view">
            <field name="name">estate.property.pivot</field>
            <field name="model">estate.property</field>
            <field name="arch" type="xml">
                <pivot string="Property Analysis">
                    <field name="expected_price" type="measure"/>
                    <field name="type_id" type="row"/>
                    <field name="state" type="col"/>
                </pivot>
            </field>
        </record>

        <!-- Graph View -->
        <record id="estate_property_graph_view" model="ir.ui.view">
            <field name="name">estate.property.graph</field>
            <field name="model">estate.property</field>
            <field name="arch" type="xml">
                <graph string="Property Analysis" type="bar">
                    <field name="expected_price" type="measure"/>
                    <field name="type_id" type="row"/>
                    <field name="state" type="col"/>
                </graph>
            </field>
        </record>


        <!-- Calendar View -->
        <record id="estate_property_calendar_view" model="ir.ui.view">
            <field name="name">estate.property.calendar</field>
            <field name="model">estate.property</field>
            <field name="arch" type="xml">
                <calendar string="Property Calendar" date_start="date_availability">
                    <field name="name"/>
                    <field name="expected_price"/>
                    <field name="state" widget="label_selection" options="{'classes': {'new': 'info', 'received': 'warning', 'accepted': 'primary', 'sold': 'success', 'cancel': 'danger'}}"/>
                </calendar>
            </field>
        </record>

        <!-- Action View -->
        <record id="action_property" model="ir.actions.act_window">
            <field name="name">properties</field>
            <field name="res_model">estate.property</field>
            <field name="view_mode">list,form,kanban,pivot,graph,calendar</field>
            <field name="view_id" ref="view_property_list"/>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create your first property for Advertisement!
                </p>
            </field>
        </record>

    </data>
</odoo>