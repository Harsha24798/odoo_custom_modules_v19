<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>

        <!-- List View -->
        <record id="view_property_tags_list" model="ir.ui.view">
            <field name="name">estate.property.tags.list</field>
            <field name="model">estate.property.tags</field>
            <field name="arch" type="xml">
                <list string="Property Tags">
                    <field name="name"/>
                    <field name="color" widget="color_picker"/>
                </list>
            </field>
        </record>

        <!-- Form View -->
        <record id="view_property_tags_form" model="ir.ui.view">
            <field name="name">estate.property.tags.form</field>
            <field name="model">estate.property.tags</field>
            <field name="arch" type="xml">
                <form string="Property Tags">
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="color" widget="color_picker"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Action View -->
        <record id="action_property_tags" model="ir.actions.act_window">
            <field name="name">estate.property.tags</field>
            <field name="res_model">estate.property.tags</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create your first property Tag
                </p>
            </field>
        </record>

        <!-- Action Menu -->
        <!-- Settings only for managers -->
        <menuitem id="menu_property_tag" name="Property Tag" parent="menu_settings" action="action_property_tags" groups="real_estate_ads.group_property_manager"/>

    </data>
</odoo>