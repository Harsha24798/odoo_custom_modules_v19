<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <!-- Sample Property 1: Modern Apartment (New) -->
        <record id="property_apartment_modern" model="estate.property">
            <field name="name">Modern Apartment in Downtown</field>
            <field name="type_id" ref="real_estate_ads.property_type_apartment"/>
            <field name="postcode">10001</field>
            <field name="date_availability">2026-06-01</field>
            <field name="description">Stunning modern apartment with panoramic city views, fully renovated kitchen, and marble bathrooms.</field>
            <field name="expected_price">350000</field>
            <field name="bedrooms">2</field>
            <field name="living_area">95</field>
            <field name="facades">1</field>
            <field name="garage">True</field>
            <field name="garden">False</field>
            <field name="garden_area">0</field>
            <field name="garden_orientation">north</field>
            <field name="state">new</field>
            <field name="tag_ids" eval="[(6, 0, [ref('real_estate_ads.property_tag_furnished')])]"/>
        </record>

        <!-- Sample Property 2: Seaside House (Offer Received) -->
        <record id="property_house_seaside" model="estate.property">
            <field name="name">Beautiful Beachfront House</field>
            <field name="type_id" ref="real_estate_ads.property_type_house"/>
            <field name="postcode">90001</field>
            <field name="date_availability">2026-05-20</field>
            <field name="description">Luxury beachfront property with direct beach access, infinity pool, and terrace overlooking the ocean.</field>
            <field name="expected_price">850000</field>
            <field name="bedrooms">4</field>
            <field name="living_area">250</field>
            <field name="facades">3</field>
            <field name="garage">True</field>
            <field name="garden">True</field>
            <field name="garden_area">150</field>
            <field name="garden_orientation">south</field>
            <field name="state">received</field>
            <field name="tag_ids" eval="[(6, 0, [ref('real_estate_ads.property_tag_sea_view'), ref('real_estate_ads.property_tag_garden')])]"/>
        </record>

        <!-- Sample Property 3: Garden Villa (Offer Accepted) -->
        <record id="property_villa_garden" model="estate.property">
            <field name="name">Elegant Garden Villa</field>
            <field name="type_id" ref="real_estate_ads.property_type_house"/>
            <field name="postcode">80001</field>
            <field name="date_availability">2026-04-15</field>
            <field name="description">Spacious villa with manicured gardens, estate wine cellar, and premium finishes throughout.</field>
            <field name="expected_price">650000</field>
            <field name="bedrooms">5</field>
            <field name="living_area">320</field>
            <field name="facades">4</field>
            <field name="garage">True</field>
            <field name="garden">True</field>
            <field name="garden_area">500</field>
            <field name="garden_orientation">west</field>
            <field name="state">accepted</field>
            <field name="tag_ids" eval="[(6, 0, [ref('real_estate_ads.property_tag_furnished'), ref('real_estate_ads.property_tag_garden'), ref('real_estate_ads.property_tag_garage')])]"/>
        </record>

        <!-- Sample Property 4: Investment Land (Sold) -->
        <record id="property_land_investment" model="estate.property">
            <field name="name">Prime Commercial Land</field>
            <field name="type_id" ref="real_estate_ads.property_type_land"/>
            <field name="postcode">75001</field>
            <field name="date_availability">2026-03-01</field>
            <field name="description">Prime commercial land in downtown development zone, perfect for mixed-use development.</field>
            <field name="expected_price">1200000</field>
            <field name="bedrooms">0</field>
            <field name="living_area">0</field>
            <field name="facades">2</field>
            <field name="garage">False</field>
            <field name="garden">False</field>
            <field name="garden_area">0</field>
            <field name="garden_orientation">north</field>
            <field name="state">sold</field>
            <field name="tag_ids" eval="[(6, 0, [])]"/>
        </record>

        <!-- Sample Property 5: Compact Studio (Canceled) -->
        <record id="property_studio_compact" model="estate.property">
            <field name="name">Cozy Studio Apartment</field>
            <field name="type_id" ref="real_estate_ads.property_type_apartment"/>
