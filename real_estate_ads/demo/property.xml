        <!-- Sample Property 8: Penthouse with Terrace (Accepted) -->
        <record id="property_penthouse" model="estate.property">
            <field name="name">Penthouse with Private Terrace</field>
            <field name="type_id" ref="real_estate_ads.property_type_apartment"/>
