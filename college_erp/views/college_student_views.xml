<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <!-- List View -->
    <record id="college_student_list_view" model="ir.ui.view">
        <field name="name">college.student.view.list</field>
        <field name="model">college.student</field>
        <field name="arch" type="xml">
            <list string="College Student List">
                <field name="admission_no"/>
                <field name="admission_date"/>
                <field name="first_name"/>
                <field name="last_name"/>
                <field name="email"/>
                <field name="mother_name" optional="hide"/>
                <field name="father_name" optional="hide"/>
                <field name="birth_day"/>
                <field name="age"/>
                <field name="phone"/>
                <field name="communication_address" optional="hide"/>
                <field name="image_1920" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="college_student_form_view" model="ir.ui.view">
        <field name="name">college.student.view.form</field>
        <field name="model">college.student</field>
        <field name="arch" type="xml">
            <form string="College Student Form" create="false">
                <header>
                        <button name="action_rainbow_effect" type="object" string="Show Rainbow Effect" class="oe_highlight" />
                    <button name="action_send_email" type="object" string="Send Email" class="oe_highlight" />
                    </header>
                <sheet>
                    <field name="image_1920" widget="image" class="oe_avatar"/>
                    <group>
                        <group>
                            <field name="admission_no"/>
                            <field name="admission_date"/>
                            <field name="first_name"/>
                            <field name="last_name"/>
                            <field name="email"/>
                            <field name="mother_name"/>
                            <field name="father_name"/>
                            <field name="birth_day"/>
                            <field name="age"/>
                        </group>
                        <group>
                            <field name="phone"/>
                            <field name="communication_address"/>
                            <field name="same_as_communication" widget="boolean_toggle"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Permanent Address" name="permanent_address" invisible="same_as_communication">
                            <group>
                                <div class="o_address_format">
                                    <field name="street" placeholder="Street..." class="o_address_street"/>
                                    <field name="street2" placeholder="Street 2..." class="o_address_street"/>
                                    <field name="city" placeholder="City" class="o_address_city"/>
                                    <field name="state_id" placeholder="State" class="o_address_state"/>
                                    <field name="zip" placeholder="ZIP" class="o_address_zip"/>
                                    <field name="country_id" placeholder="Country" class="o_address_country" groups="base.group_user"/>
                                </div>
                            </group>
                        </page>
                    </notebook>

                </sheet>
            </form>
        </field>
    </record>

    <!-- Window Action -->
    <record id="action_college_erp" model="ir.actions.act_window">
        <field name="name">College ERP</field>
        <field name="res_model">college.student</field>
        <field name="view_mode">list,form,kanban</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Welcome to College ERP! Click the button below to create your first student record.
            </p>
        </field>
    </record>

    <!-- Action Menu -->
     <menuitem id="college_erp_menu_student" name="Student" parent="college_erp.college_erp_menu_dashboard" action="action_college_erp" sequence="1"/>
</odoo>